{
  "name": "kitchenkin",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @kk/web --filter @kk/api-server dev",
    "dev:web": "bun run --filter @kk/web dev",
    "dev:api": "bun run --filter @kk/api-server dev",
    "build": "bun run --filter @kk/web build",
    "lint": "bun run --filter @kk/web lint",
    "gql": "bun run --filter @kk/graphql gql",
    "prisma-sanity": "bun run --filter @kk/web prisma-sanity",
    "review-packet": "bun run --filter @kk/web review-packet"
  },
  "engines": {
    "node": "22.x"
  },
  "trustedDependencies": [
    "prisma"
  ],
  "resolutions": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "overrides": {
    "p-limit": "4.0.0"
  }
}
